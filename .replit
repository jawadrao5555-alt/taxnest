modules = ["php-8.4", "nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[userenv]

[userenv.shared]
APP_URL = "http://0.0.0.0:5000"
DB_CONNECTION = "pgsql"
DB_PORT = "5432"
DB_PASSWORD = ""
DB_HOST = "127.0.0.1"
DB_USERNAME = "root"
DB_DATABASE = "laravel"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Laravel Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Queue Worker"

[[workflows.workflow]]
name = "Laravel Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "php artisan serve --host=0.0.0.0 --port=5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Queue Worker"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "php artisan queue:work"

[[ports]]
localPort = 5000
externalPort = 80

[nix]
channel = "stable-25_05"
